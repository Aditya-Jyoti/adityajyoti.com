---
import Tape from "./Tape.astro";
import Squiggle from "./Squiggle.astro";

interface Props {
  title: string;
  description: string;
  link: string;
  handdrawn_style: string;
}

const { title, description, link, handdrawn_style } = Astro.props;

const colors = ["yellow", "red", "aqua", "blue", "purple", "green"] as const;
function hash(s: string) {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
  return Math.abs(h);
}
const h = hash(title);
const tape1Color = colors[h % colors.length];
const tape2Color = colors[(h >> 3) % colors.length];
const rot1 = -16 + ((h >> 5) % 10); // -16 to -7
const rot2 = 7 + ((h >> 7) % 10); // 7 to 16
---

<section class="card-wrap relative block w-full lg:flex-1 mb-3 mr-2">
  <!-- back paper layers (progressively darker, jagged borders) -->
  <div
    class:list={[
      handdrawn_style,
      "paper-back paper-back-2 wobble absolute inset-0 border-2 border-foreground",
    ]}
  >
  </div>
  <div
    class:list={[
      handdrawn_style,
      "paper-back paper-back-1 wobble absolute inset-0 border-2 border-foreground",
    ]}
  >
  </div>

  <!-- main paper: background filled below, jagged border drawn on top -->
  <a
    href={link}
    target="_blank"
    class:list={[
      handdrawn_style,
      "card-face relative block lg:h-56 h-52 w-full bg-background p-4 text-foreground hover:text-foreground",
    ]}
  >
    <div
      class:list={[
        handdrawn_style,
        "card-face-border wobble pointer-events-none absolute inset-0 border-2 border-foreground",
      ]}
    >
    </div>
    <div class="relative z-10 flex flex-col h-full">
      <div class="flex-grow">
        <div>
          <span class="lg:text-xl text-lg font-bold">{title}</span>
          <Squiggle class="w-20" />
        </div>
        <div class="py-2">{description}</div>
      </div>
      <div class="w-full flex justify-end text-lg">
        <span class="hover:underline underline-offset-2">project link</span>
      </div>
    </div>
  </a>

  <Tape color={tape1Color} side="left" inset={12} top="0px" rotate={rot1} width={64} />
  <Tape color={tape2Color} side="right" inset={12} top="0px" rotate={rot2} width={60} />
</section>

<style>
  .card-face,
  .paper-back {
    transition:
      transform 220ms ease,
      box-shadow 220ms ease;
  }
  .wobble {
    filter: url(#card-wobble);
  }
  .paper-back-1 {
    background: #ecdfa8;
    transform: translate(4px, 4px) rotate(0.6deg);
    z-index: 0;
  }
  .paper-back-2 {
    background: #1d2021;
    transform: translate(7px, 7px) rotate(-0.9deg);
    z-index: -1;
  }
  .card-face {
    z-index: 1;
  }
  .card-wrap:hover .card-face {
    transform: translate(-2px, -3px) rotate(-0.6deg);
  }
  .card-wrap:hover .paper-back-1 {
    transform: translate(5px, 5px) rotate(0.9deg);
  }
  .card-wrap:hover .paper-back-2 {
    transform: translate(9px, 9px) rotate(-1.4deg);
  }
  .card-wrap:active .card-face {
    transform: translate(1px, 1px) rotate(0deg);
    transition-duration: 80ms;
  }
  .card-wrap:active .paper-back-1 {
    transform: translate(2px, 2px) rotate(0.4deg);
    transition-duration: 80ms;
  }
  .card-wrap:active .paper-back-2 {
    transform: translate(5px, 5px) rotate(-0.6deg);
    transition-duration: 80ms;
  }
</style>
