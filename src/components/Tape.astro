---
// A piece of colored "tape" used to make cards feel like they're stuck on
// the page. Sits absolutely positioned on its parent.

type Color = "yellow" | "red" | "aqua" | "blue" | "purple" | "green";
type Side = "left" | "right";

type Props = {
  color?: Color;
  side?: Side;
  // distance from the chosen side, in px (defaults to a small inset so
  // the tape sits near the corner without spilling past it)
  inset?: number;
  // vertical offset from the parent's top edge, e.g. "-10px"
  top?: string;
  width?: number;
  height?: number;
  rotate?: number;
  class?: string;
};

const {
  color = "yellow",
  side = "left",
  inset = 14,
  top = "-10px",
  width = 56,
  height = 18,
  rotate = -18,
  class: extra = "",
} = Astro.props;

const colorMap: Record<Color, string> = {
  yellow: "#fabd2f",
  red: "#fb4934",
  aqua: "#8ec07c",
  blue: "#83a598",
  purple: "#d3869b",
  green: "#b8bb26",
};

const bg = colorMap[color];
const sideStyle = side === "left" ? `left:${inset}px;` : `right:${inset}px;`;
// Pivot near the bottom-edge corner closest to the card body so the far end
// of the tape swings only a little above the card when rotated.
const origin = side === "left" ? "left bottom" : "right bottom";
---

<span
  class:list={["tape pointer-events-none absolute z-30 block", extra]}
  style={`top:${top};${sideStyle}width:${width}px;height:${height}px;transform:rotate(${rotate}deg);transform-origin:${origin};background:${bg};`}
  aria-hidden="true"
>
</span>

<style>
  .tape {
    opacity: 0.78;
    box-shadow:
      inset 4px 0 6px -4px rgba(0, 0, 0, 0.18),
      inset -4px 0 6px -4px rgba(0, 0, 0, 0.18),
      0 1px 2px rgba(0, 0, 0, 0.08);
    clip-path: polygon(
      0% 8%,
      6% 0%,
      18% 6%,
      32% 0%,
      48% 4%,
      62% 0%,
      78% 6%,
      92% 0%,
      100% 8%,
      100% 92%,
      94% 100%,
      80% 94%,
      66% 100%,
      52% 96%,
      38% 100%,
      22% 94%,
      8% 100%,
      0% 92%
    );
  }
</style>
