---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

import "../styles/global.css";
import "../styles/post.css";

type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage, imgDesc } =
  Astro.props;

const heroWebp = heroImage
  ? heroImage.replace(/\.(png|jpe?g)$/i, ".webp")
  : undefined;
---

<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={heroImage}
      type="article"
      pubDate={pubDate}
      updatedDate={updatedDate}
      preloadImage={heroImage}
      preloadImageWebp={heroWebp}
    />
  </head>

  <body
    class="bg-background text-foreground flex flex-col min-h-screen max-w-3xl w-full px-4 lg:px-6 lg:py-4 mx-auto font-blog"
  >
    <Header />
    <main class="flex-1 w-full">
      <article>
        <header class="mt-6 mb-6">
          <h1 class="font-bold leading-tight tracking-tight text-3xl lg:text-4xl">
            {title}
          </h1>
          <div class="w-24 h-1 bg-foreground rounded-full mt-3"></div>

          <p class="mt-3 text-base lg:text-lg">
            by <a href="/blog" class="font-bold underline underline-offset-2">Aditya Jyoti</a>
          </p>

          <div class="mt-2 text-xs lg:text-sm opacity-70 flex flex-wrap gap-x-3 gap-y-1">
            <span>
              Published <FormattedDate date={pubDate} />
            </span>
            {
              updatedDate && updatedDate.valueOf() !== pubDate.valueOf() && (
                <span>
                  · Updated <FormattedDate date={updatedDate} />
                </span>
              )
            }
          </div>
        </header>

        {
          heroImage && (
            <figure class="my-6">
              <picture>
                {heroWebp && <source srcset={heroWebp} type="image/webp" />}
                <img
                  src={heroImage}
                  alt={imgDesc || title}
                  width="1200"
                  height="630"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                  class="w-full h-auto rounded-xl border border-foreground/15"
                />
              </picture>
              {imgDesc && (
                <figcaption class="text-center text-sm lg:text-base mt-2 italic opacity-70">
                  {imgDesc}
                </figcaption>
              )}
            </figure>
          )
        }

        <div class="prose">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
