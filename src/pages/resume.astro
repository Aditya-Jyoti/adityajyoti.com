---
const resumeUrl = "/resume.pdf";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Downloading résumé — Aditya Jyoti</title>
    <link rel="canonical" href="https://adityajyoti.in/" />
  </head>
  <body style="font-family: system-ui, sans-serif; max-width: 36rem; margin: 4rem auto; padding: 0 1rem; line-height: 1.6;">
    <p>
      Downloading résumé… if nothing happens,
      <a href={resumeUrl} download="adityajyoti_resume.pdf">click here</a>.
    </p>
    <script is:inline define:vars={{ resumeUrl }}>
      const a = document.createElement("a");
      a.href = resumeUrl;
      a.download = "adityajyoti_resume.pdf";
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => {
        window.location.replace("/");
      }, 600);
    </script>
  </body>
</html>
