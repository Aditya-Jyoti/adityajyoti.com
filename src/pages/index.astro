---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import FormattedDate from "../components/FormattedDate.astro";
import BackgroundDoodles from "../components/BackgroundDoodles.astro";
import Squiggle from "../components/Squiggle.astro";
import StickyCard from "../components/StickyCard.astro";

import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import "../styles/global.css";

import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allEats = (await getCollection("khana")).sort(
  (a: any, b: any) =>
    b.data.dateOfVisit.valueOf() - a.data.dateOfVisit.valueOf()
);
const mostRecentPinned = allEats.find((p: any) => p.data.pinned);
const mostRecent = allEats.find((p: any) => p.id !== mostRecentPinned?.id);
const featuredEats = [mostRecentPinned, mostRecent].filter(Boolean);

const allWatches = (await getCollection("watches")).sort(
  (a: any, b: any) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0)
);
const featuredWatches = allWatches.slice(0, 2);
const watchProgressLabel: Record<string, string> = {
  consuming: "currently consuming",
  want: "want to consume",
  finished: "finished",
  dropped: "left",
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      preloadImage="/Person.svg"
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "@id": "https://adityajyoti.in/#person",
            name: "Aditya Jyoti",
            url: "https://adityajyoti.in",
            image: "https://adityajyoti.in/me-sketch.png",
            sameAs: [
              "https://github.com/aditya-jyoti",
              "https://linkedin.com/in/aditya-jyoti",
            ],
            email: "mailto:website@adityajyoti.in",
            jobTitle: "Software Engineer",
            description: SITE_DESCRIPTION,
          },
          {
            "@type": "WebSite",
            "@id": "https://adityajyoti.in/#website",
            url: "https://adityajyoti.in",
            name: SITE_TITLE,
            description: SITE_DESCRIPTION,
            publisher: { "@id": "https://adityajyoti.in/#person" },
            inLanguage: "en",
          },
        ],
      })}
    />
  </head>
  <body
    class="bg-background text-foreground flex flex-col min-h-screen lg:w-[60%] p-4 lg:p-0 mx-auto font-handwriting relative overflow-x-clip"
  >
    <BackgroundDoodles />
    <Header />

    <section class="flex-grow flex flex-col gap-4">
      <!-- root -->
      <section
        id="root"
        class="flex lg:flex-row flex-col justify-between items-center lg:w-[90%] mx-auto lg:py-12"
      >
        <div class="w-full lg:hidden justify-center flex">
          <img
            src="/Person.svg"
            alt="Sketch of Aditya Jyoti"
            width="256"
            height="321"
            fetchpriority="high"
            decoding="async"
            class="h-64 w-auto p-2"
          />
        </div>
        <div
          class="flex flex-col lg:text-xl text-lg lg:w-fit w-full lg:text-left text-center"
        >
          <h1 class="lg:text-4xl text-2xl font-black">
            Hey! I'm Aditya Jyoti
          </h1>
          <span
            class="lg:text-lg text-sm flex items-center lg:justify-start justify-center"
            >breaking things since... <img
              src="/shushing-face.svg"
              alt="sush emoji"
              class="lg:w-10 w-8 aspect-square"
            />
          </span>

          <span
            >A diehard engineer using tech to cope with the struggles of life.
            Susceptible to doing things just because they look "cool"</span
          >

          <div
            class="relative flex justify-center lg:justify-start gap-4 font-semibold text-sm mt-4"
          >
            <!-- button 1 -->
            <div class="relative">
              <div
                class="handdrawn-1 flex items-center justify-center border-2 w-full h-10 absolute top-0 left-0 z-10 bg-background border-foreground hover:translate-x-0.5 hover:translate-y-0.5 transition-all ease-in-out duration-300"
              >
                <a
                  href="https://linkedin.com/in/aditya-jyoti"
                  target="_blank"
                  class="mt-1 w-full text-center">LINKEDIN</a
                >
              </div>
              <div
                class="handdrawn-1 lg:w-56 w-36 h-10 bg-foreground translate-x-1 translate-y-1"
              >
              </div>
            </div>
            <!-- button 1 -->
            <div class="relative">
              <div
                class="handdrawn-5 flex items-center justify-center w-full h-10 absolute top-0 left-0 z-10 text-background bg-foreground hover:translate-x-0.5 hover:translate-y-0.5 transition-all ease-in-out duration-300"
              >
                <a
                  href="https://github.com/aditya-jyoti"
                  target="_blank"
                  class="handdrawn-3 mt-1 w-full text-center">GITHUB</a
                >
              </div>
              <div
                class="handdrawn-5 lg:w-56 w-36 h-10 bg-background border-2 border-foreground translate-x-1 translate-y-1"
              >
              </div>
            </div>
          </div>
        </div>
        <div class="w-full lg:flex justify-center hidden pl-16">
          <img
            src="/Person.svg"
            alt="Sketch of Aditya Jyoti"
            width="256"
            height="321"
            fetchpriority="high"
            decoding="async"
            class="h-96 w-auto p-2"
          />
        </div>
      </section>

      <!-- projects -->
      <section id="projects" class="flex flex-col gap-4">
        <div class="flex flex-col w-full items-end">
          <h2 class="lg:text-4xl text-2xl font-bold">Projects</h2>
          <Squiggle class="lg:w-24 w-12" />
        </div>

        <div class="lg:text-xl text-right">
          I have worked on multiple fullstack projects and my biggest
          achievement has to be contributing to the technical infrastructure of
          the college I study in. Currently I am learning devops and am trying
          to self host my life.
        </div>

        <!-- project card -->
        <div class="flex lg:flex-row flex-col gap-6 lg:gap-8 w-full lg:my-8">
          <ProjectCard
            handdrawn_style="handdrawn-1"
            title="Recruitment Site"
            description="A supabase powered recruitment side handling the recruitment of over 800 people for IEEE Computer Society"
            link="https://github.com/ComputerSocietyVITC/Recruitment-Site-Frontend/"
          />
          <ProjectCard
            handdrawn_style="handdrawn-3"
            title="Hono API Template"
            description="An easy to setup REST API template using Hono. Uses prisma, postgresql and minio. Comes with RBAC and deployment options."
            link="https://github.com/Aditya-Jyoti/Hono-API-Template/"
          />
          <ProjectCard
            handdrawn_style="handdrawn-4"
            title="Custom Shell"
            description="A work in progress custom shell written in C++ made to learn the workings of linux commands."
            link="https://github.com/Aditya-Jyoti/Custom-Shell"
          />
        </div>

        <div class="lg:text-xl text-lg my-2">
          you can find more projects over at my <a
            href="https://github.com/aditya-jyoti"
            target="_blank"
            class="underline underline-offset-2">github</a
          >...
        </div>
      </section>

      <!-- what i do -->
      <section id="whatido" class="pt-10 lg:pt-14 pb-2">
        <div class="flex flex-col w-full mb-6 lg:mb-8">
          <h2 class="lg:text-4xl text-2xl font-bold">What I Do</h2>
          <Squiggle class="lg:w-24 w-12" />
        </div>

        <section class="flex flex-col gap-7">
          {
            [
              {
                title: "Robotics",
                body: "I love building things from scratch. Imagine a world where all the hardware you use was sourced and built by yourself. That's the world I want to live in.",
                accent: "border-aqua",
              },
              {
                title: "Programming",
                body: "Programming feels like magic to me. It gives me the freedom to explore and build my own world with only my imagination as a limit.",
                accent: "border-yellow",
              },
              {
                title: "Public Speaking",
                body: "Seeing everyone's eyes on me, listening to my every word and so much more gives me more adrenaline than anything in the world.",
                accent: "border-red",
              },
            ].map((item) => (
              <div class={`border-l-4 ${item.accent} pl-4 lg:pl-5 flex flex-col gap-1`}>
                <span class="font-bold lg:text-2xl text-xl leading-tight">
                  {item.title}
                </span>
                <span class="lg:text-lg text-base">{item.body}</span>
              </div>
            ))
          }
        </section>
      </section>

      <!-- blog  -->
      <section id="blog" class="flex flex-col gap-4">
        <div class="flex flex-col w-full items-end">
          <h2 class="lg:text-4xl text-2xl font-bold">I Also Write</h2>
          <Squiggle class="w-32" />
        </div>
        <!-- content -->
        <section class="grid grid-cols-1 lg:grid-cols-2 gap-x-6 gap-y-8">
          {
            posts
              .slice(0, 2)
              .map(
                (post: {
                  data: { title: unknown; description: unknown; pubDate: Date };
                  id: any;
                }) => (
                  <StickyCard
                    href={`/blog/writes/${post.id}`}
                    seed={String(post.id)}
                    handdrawn={`handdrawn-${(String(post.id).length % 5) + 1}`}
                    faceClass="min-h-[8rem] lg:h-36"
                  >
                    <div class="flex flex-col gap-2 w-full h-full">
                      <span class="text-lg lg:text-xl font-bold leading-tight">
                        {post.data.title}
                      </span>
                      <span class="text-sm lg:text-base flex-grow line-clamp-2">
                        {post.data.description}
                      </span>
                      <div class="w-full flex text-sm lg:text-base justify-between opacity-80">
                        <FormattedDate date={post.data.pubDate} />
                      </div>
                    </div>
                  </StickyCard>
                )
              )
          }
        </section>

        <div class="lg:text-lg text-base mt-1">
          more posts on <i class="font-bold">Aditya Writes</i> → <a
            href="/blog/writes"
            class="underline underline-offset-2">here</a
          >
        </div>
      </section>

      <!-- eats -->
      {
        featuredEats.length > 0 && (
          <section id="eats" class="flex flex-col gap-4">
            <div class="flex flex-col w-full">
              <h2 class="lg:text-4xl text-2xl font-bold">I Also Eat</h2>
              <Squiggle class="w-28" />
            </div>

            <section class="grid grid-cols-1 lg:grid-cols-2 gap-x-6 gap-y-8">
              {featuredEats.map(
                (post: {
                  id: any;
                  data: {
                    title: string;
                    description: string;
                    location: string;
                    cuisine: string;
                    dateOfVisit: Date;
                    rating: number;
                  };
                }) => (
                  <StickyCard
                    href={`/blog/eats/${post.id}`}
                    seed={String(post.id)}
                    handdrawn={`handdrawn-${(String(post.id).length % 5) + 1}`}
                    faceClass="min-h-[9rem] lg:h-40"
                  >
                    <div class="flex flex-col gap-2 w-full h-full">
                      <div class="flex justify-between items-start gap-2">
                        <span class="text-lg lg:text-xl font-bold leading-tight">
                          {post.data.title}
                        </span>
                        <span class="shrink-0 text-xs lg:text-sm font-bold bg-yellow border-2 border-foreground px-2 py-0.5 handdrawn-2">
                          ★ {Number.isInteger(post.data.rating) ? post.data.rating.toFixed(0) : post.data.rating.toFixed(1)}/5
                        </span>
                      </div>
                      <span class="text-sm lg:text-base flex-grow line-clamp-2">
                        {post.data.description}
                      </span>
                      <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs lg:text-sm opacity-80">
                        <span>📍 {post.data.location}</span>
                        <span>🍽 {post.data.cuisine}</span>
                      </div>
                      <div class="w-full flex text-sm lg:text-base justify-between opacity-80">
                        <FormattedDate date={post.data.dateOfVisit} />
                      </div>
                    </div>
                  </StickyCard>
                )
              )}
            </section>

            <div class="lg:text-lg text-base mt-1">
              more spots on <i class="font-bold">Aditya Eats</i> → <a
                href="/blog/eats"
                class="underline underline-offset-2">here</a
              >
            </div>
          </section>
        )
      }

      <!-- watches -->
      {
        featuredWatches.length > 0 && (
          <section id="watches" class="flex flex-col gap-4">
            <div class="flex flex-col w-full items-end">
              <h2 class="lg:text-4xl text-2xl font-bold">I Also Watch</h2>
              <Squiggle class="w-32" />
            </div>

            <section class="grid grid-cols-1 lg:grid-cols-2 gap-x-6 gap-y-8">
              {featuredWatches.map(
                (post: {
                  id: any;
                  data: {
                    title: string;
                    mediaType: string;
                    progress: string;
                    rating?: number;
                    notes?: string;
                    genre?: string[];
                    date?: Date;
                  };
                }) => (
                  <StickyCard
                    href="/blog/watches"
                    seed={String(post.id)}
                    handdrawn={`handdrawn-${(String(post.id).length % 5) + 1}`}
                    faceClass="min-h-[9rem] lg:h-40"
                  >
                    <div class="flex flex-col gap-2 w-full h-full">
                      <div class="flex justify-between items-start gap-2">
                        <span class="text-lg lg:text-xl font-bold leading-tight">
                          {post.data.title}
                        </span>
                        {post.data.rating !== undefined && (
                          <span class="shrink-0 text-xs lg:text-sm font-bold bg-yellow border-2 border-foreground px-2 py-0.5 handdrawn-2">
                            ★ {Number.isInteger(post.data.rating) ? post.data.rating.toFixed(0) : post.data.rating.toFixed(1)}/5
                          </span>
                        )}
                      </div>
                      <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs lg:text-sm opacity-80">
                        <span class="lowercase">🎬 {post.data.mediaType}</span>
                        <span>· {watchProgressLabel[post.data.progress]}</span>
                      </div>
                      <span class="text-sm lg:text-base flex-grow line-clamp-2">
                        {post.data.notes ??
                          (post.data.genre && post.data.genre.length > 0
                            ? post.data.genre.join(", ")
                            : "")}
                      </span>
                      {post.data.date && (
                        <div class="w-full flex text-sm lg:text-base justify-between opacity-80">
                          <FormattedDate date={post.data.date} />
                        </div>
                      )}
                    </div>
                  </StickyCard>
                )
              )}
            </section>

            <div class="lg:text-lg text-base mt-1">
              more on <i class="font-bold">Aditya Watches</i> → <a
                href="/blog/watches"
                class="underline underline-offset-2">here</a
              >
            </div>
          </section>
        )
      }

      <!-- contact -->
      <section id="contact" class="flex flex-col gap-4">
        <div class="flex flex-col w-full items-end">
          <h2 class="lg:text-4xl text-2xl font-bold">Talk To Me (please)</h2>
          <Squiggle class="lg:w-44 w-24" />
        </div>

        <div class="lg:text-xl text-lg">
          You can send me an email at
          <a href="mailto:website@adityajyoti.in"
            ><strong>website@adityajyoti.in</strong></a
          >
          and I will respond promptly, or you can leave a message here.
        </div>

        <!-- 👇 Formspree form starts here -->
        <form
          action="https://formspree.io/f/xeozewvd"
          method="POST"
          class="flex flex-col gap-4 relative"
        >
          <div class="flex gap-4">
            <!-- name -->
            <div class="relative w-full">
              <span class="text-xl">name </span>
              <div class="w-full">
                <input
                  required
                  type="text"
                  name="name"
                  placeholder="your name..."
                  class="p-2 border-2 hover:translate-x-0.5 hover:translate-y-0.5 transition-all duration-300 ease-in-out w-full absolute z-10 border-foreground bg-background handdrawn-3 selection:border-foreground text-foreground placeholder-foreground"
                />
                <input
                  type="text"
                  placeholder="Name"
                  readonly
                  class="p-2 border-2 w-full border-foreground bg-foreground translate-x-1 translate-y-1 handdrawn-3 text-foreground placeholder-foreground"
                />
              </div>
            </div>

            <!-- email -->
            <div class="relative w-full">
              <span class="text-xl">email </span>
              <div class="w-full">
                <input
                  required
                  type="email"
                  name="email"
                  placeholder="your email..."
                  class="p-2 border-2 hover:translate-x-0.5 hover:translate-y-0.5 transition-all duration-300 ease-in-out w-full absolute z-10 border-foreground bg-background handdrawn-5 selection:border-foreground text-foreground placeholder-foreground"
                />
                <input
                  type="email"
                  placeholder="Email"
                  readonly
                  class="p-2 border-2 w-full border-foreground bg-foreground translate-x-1 translate-y-1 handdrawn-3 text-foreground placeholder-foreground"
                />
              </div>
            </div>
          </div>

          <!-- message -->
          <div class="relative w-full">
            <span class="text-xl">message </span>
            <div class="w-full">
              <textarea
                required
                name="message"
                rows="4"
                placeholder="Please write your message (I read everything)..."
                class="p-2 border-2 hover:translate-x-0.5 hover:translate-y-0.5 transition-all duration-300 ease-in-out w-full absolute z-10 border-foreground bg-background handdrawn-1 resize-none selection:border-foreground text-foreground placeholder-foreground"
              ></textarea>
              <textarea
                placeholder="Message"
                rows="4"
                readonly
                class="p-2 border-2 w-full border-foreground resize-none bg-foreground translate-x-1 translate-y-1 handdrawn-3 text-foreground placeholder-foreground"
              ></textarea>
            </div>
          </div>

          <button
            type="submit"
            class="p-2 bg-foreground text-background font-bold handdrawn-4 hover:bg-background hover:text-foreground transition-all duration-300 ease-in-out border-2 border-foreground"
          >
            Send
          </button>
        </form>
      </section>
    </section>

    <Footer />
  </body>
</html>
