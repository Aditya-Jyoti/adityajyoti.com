---
import Layout from "../layouts/Layout.astro";

import Navbar from "../components/Navbar.astro";
---

<Layout>
  <main class="flex flex-col w-full bg-custom-light-white">
    <Navbar />
    <section
      id="about"
      class="bg-custom-light-white flex md:flex-row flex-col md:justify-between md:items-center md:m-auto md:max-w-[70%]"
    >
      <div class="flex flex-col md:w-[50%] gap-4 md:p-0 p-4">
        <span class="md:text-4xl text-3xl font-bold"
          >Hello. I am Aditya Jyoti.</span
        >
        <span class="md:text-2xl text-xl"
          >A die hard engineer looking forward to breaking open things and then
          never being able to put them back together. <br /> I also code sometimes.</span
        >

        <a href="https://www.linkedin.com/in/aditya-jyoti/" target="_blank">
          <div class="relative">
            <div
              class="absolute z-10 bg-custom-light-grey border-2 border-black w-fit p-2 font-bold hover:translate-x-0.5 hover:translate-y-0.5 transition-all duration-150"
            >
              Connect With Me
            </div>
            <div
              class="absolute z-0 bg-custom-black border-2 border-black w-fit p-2 font-bold translate-x-1 translate-y-1"
            >
              Connect With Me
            </div>
          </div>
        </a>
      </div>
      <img
        src="/img-small.png"
        alt="profile"
        class="flex ml-auto md:hidden w-64 -mt-14"
      />
      <img src="/img-long.png" alt="profile" class="md:flex hidden" />
    </section>
  </main>
</Layout>
