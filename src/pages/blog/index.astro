---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import "../../styles/global.css";

const posts = (await getCollection("blog")).sort(
  (a: { data: { pubDate: Date } }, b: { data: { pubDate: Date } }) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const styles = posts.map(() => ({
  card: Math.floor(Math.random() * 5) + 1,
  shadow: Math.floor(Math.random() * 5) + 1,
}));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>

  <body
    class="bg-background text-foreground flex flex-col min-h-screen lg:w-[60%] p-4 lg:p-0 mx-auto font-handwriting"
  >
    <Header />
    <main class="flex-grow">
      <div class="text-3xl font-bold pt-4">Aditya Writes...</div>
      <div class="lg:text-xl text-lg p-4">
        I have always wanted to maintain a blog, a place where I could write
        about what's happening in life and document the cool stuff I find. The
        only issue is, is that I am hella lazy. But, I am going to try and keep
        this blog updated with the cool stuff I find and the cool stuff I do.
        So, here is my blog. Enjoy!
      </div>

      <!-- search -->
      <div class="relative h-12 mb-6 mx-1">
        <label for="blog-search" class="sr-only">Search posts</label>
        <input
          id="blog-search"
          type="text"
          autocomplete="off"
          placeholder="search posts..."
          class="absolute top-0 left-0 w-full h-full px-4 text-lg border-2 z-10 border-foreground bg-background handdrawn-2 text-foreground placeholder-foreground/60 focus:outline-none hover:translate-x-0.5 hover:translate-y-0.5 focus:translate-x-0.5 focus:translate-y-0.5 transition-all duration-300 ease-in-out"
        />
        <div
          class="absolute top-0 left-0 w-full h-full border-2 bg-foreground border-foreground translate-x-1 translate-y-1 handdrawn-2"
        >
        </div>
      </div>

      <section>
        <div
          id="blog-list"
          class="grid lg:grid-cols-2 grid-cols-1 gap-x-5 gap-y-6"
        >
          {
            posts.map(
              (
                post: {
                  id: any;
                  data: {
                    title: string;
                    pubDate: Date;
                    description: string;
                    updatedDate?: Date;
                  };
                },
                i: number
              ) => (
                <div
                  class="blog-card relative"
                  data-title={post.data.title.toLowerCase()}
                  data-description={post.data.description.toLowerCase()}
                >
                  <a
                    href={`/blog/${post.id}/`}
                    class={`relative z-10 flex flex-col gap-2 p-4 h-full border-2 border-foreground bg-background hover:translate-x-0.5 hover:translate-y-0.5 transition-all duration-300 ease-in-out handdrawn-${styles[i].card}`}
                  >
                    <div class="lg:text-xl text-lg font-bold leading-tight">
                      {post.data.title}
                    </div>
                    <div class="text-base flex-grow">
                      {post.data.description}
                    </div>
                    <div class="flex justify-between items-end pt-1 text-sm gap-2">
                      <span class="font-bold">
                        <FormattedDate date={post.data.pubDate} />
                      </span>
                      <span class="opacity-70 text-xs lg:text-sm">
                        updated{" "}
                        <FormattedDate
                          date={post.data.updatedDate || post.data.pubDate}
                        />
                      </span>
                    </div>
                  </a>
                  <div
                    class={`absolute inset-0 border-2 border-foreground bg-foreground translate-x-1 translate-y-2 handdrawn-${styles[i].shadow}`}
                  />
                </div>
              )
            )
          }
        </div>

        <div
          id="no-results"
          class="hidden text-center text-lg lg:text-xl py-12 opacity-70"
        >
          no posts match your search :(
        </div>
      </section>
    </main>
    <Footer />

    <script>
      const search = document.getElementById(
        "blog-search"
      ) as HTMLInputElement | null;
      const cards = document.querySelectorAll<HTMLElement>(".blog-card");
      const empty = document.getElementById("no-results");

      const filter = () => {
        if (!search) return;
        const q = search.value.trim().toLowerCase();
        let visible = 0;
        cards.forEach((card) => {
          const title = card.dataset.title || "";
          const description = card.dataset.description || "";
          const matches = !q || title.includes(q) || description.includes(q);
          card.style.display = matches ? "" : "none";
          if (matches) visible++;
        });
        if (empty) empty.classList.toggle("hidden", visible !== 0);
      };

      search?.addEventListener("input", filter);
    </script>
  </body>
</html>
